{{- $dataHome := env "XDG_DATA_HOME" | default (joinPath .chezmoi.homeDir ".local/share") -}}
{{- $dpSrc := stat (joinPath $dataHome "dracula-pro/themes/sublime") -}}
{{- if $dpSrc }}
RSTUDIO_THEME_DARK=Dracula Pro
RSTUDIO_THEME_LIGHT=Dracula Pro Alucard
{{- else }}
RSTUDIO_THEME_DARK=Dracula
RSTUDIO_THEME_LIGHT=Xcode
{{- end }}

{{- if stat (joinPath .chezmoi.homeDir "git" "github" "acidgenomics" "r-acidgenomics-com") }}
ACIDGENOMICS_REPO={{ .chezmoi.homeDir }}/git/github/acidgenomics/r-acidgenomics-com
{{- end }}

{{- if stat (joinPath .chezmoi.homeDir ".local" "share" "koopa" "bin" "python3") }}
RETICULATE_PYTHON={{ .chezmoi.homeDir }}/.local/share/koopa/bin/python3
{{- end }}

{{- if stat (joinPath $dataHome "ca-certificates" "cacert.pem") }}
AWS_CA_BUNDLE={{ $dataHome }}/ca-certificates/cacert.pem
CURL_CA_BUNDLE={{ $dataHome }}/ca-certificates/cacert.pem
DEFAULT_CA_BUNDLE_PATH={{ dir $dataHome }}
REQUESTS_CA_BUNDLE={{ $dataHome }}/ca-certificates/cacert.pem
SSL_CERT_FILE={{ $dataHome }}/ca-certificates/cacert.pem
{{- else if and (eq .chezmoi.os "linux") (stat "/etc/ssl/certs/ca-certificates.crt") }}
AWS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
CURL_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
DEFAULT_CA_BUNDLE_PATH=/etc/ssl/certs
REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
{{- end }}

{{- if env "HTTP_PROXY" }}
HTTP_PROXY={{ env "HTTP_PROXY" }}
http_proxy={{ env "HTTP_PROXY" }}
{{- end }}

{{- if env "HTTPS_PROXY" }}
HTTPS_PROXY={{ env "HTTPS_PROXY" }}
https_proxy={{ env "HTTPS_PROXY" }}
{{- end }}
