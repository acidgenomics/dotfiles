#!/usr/bin/env bash

# """
# Bash shell configuration.
# Refer to '~/.profile' file for POSIX shell configuration details.
# """

__dotfiles_bashrc() {
    case "${BASH_VERSION:-}" in
        '1.'* | '2.'* | '3.'*)
            return 0
            ;;
    esac
    [[ "$-" == *i* ]] || return 0
    if [[ -f "${HOME}/.profile" ]]
    then
        # shellcheck source=/dev/null
        source "${HOME}/.profile"
    fi
    # FZF color scheme — set after .profile so we override koopa's default.
    # koopa's activate-fzf.sh only sets FZF_DEFAULT_OPTS when it is unset,
    # so this export here (post-activation) takes precedence.
{{- $dpProInstalled := stat (joinPath .chezmoi.homeDir ".local/share/dracula-pro") }}
{{ if eq (env "KOOPA_COLOR_MODE") "dark" -}}
    export FZF_DEFAULT_OPTS='--color=fg:#f8f8f2,bg:#282a36,hl:#bd93f9 --color=fg+:#f8f8f2,bg+:#44475a,hl+:#bd93f9 --color=info:#ffb86c,prompt:#50fa7b,pointer:#ff79c6 --color=marker:#ff79c6,spinner:#ffb86c,header:#6272a4'
{{- else if $dpProInstalled -}}
    export FZF_DEFAULT_OPTS='--color=fg:#383a42,bg:#fafafa,hl:#a626a4 --color=fg+:#383a42,bg+:#e8e8e8,hl+:#a626a4 --color=info:#986801,prompt:#50a14f,pointer:#e45649 --color=marker:#e45649,spinner:#986801,header:#a0a1a7'
{{- else -}}
    export FZF_DEFAULT_OPTS='--color=fg:#383a42,bg:#fafafa,hl:#a626a4 --color=fg+:#383a42,bg+:#e8e8e8,hl+:#a626a4 --color=info:#986801,prompt:#50a14f,pointer:#a626a4 --color=marker:#a626a4,spinner:#986801,header:#a0a1a7'
{{- end }}
    return 0
}

__dotfiles_bashrc
