{{- $dataHome := env "XDG_DATA_HOME" | default (joinPath .chezmoi.homeDir ".local/share") -}}
{
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": false,
  "autoUpdatesChannel": "latest",
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "astral@astral-sh": true,
    "claude-code-setup@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
{{- if stat (joinPath $dataHome "ca-certificates" "cacert.pem") }}
    "AWS_CA_BUNDLE": "{{ $dataHome }}/ca-certificates/cacert.pem",
    "CURL_CA_BUNDLE": "{{ $dataHome }}/ca-certificates/cacert.pem",
    "DEFAULT_CA_BUNDLE_PATH": "{{ dir $dataHome }}",
    "REQUESTS_CA_BUNDLE": "{{ $dataHome }}/ca-certificates/cacert.pem",
    "SSL_CERT_FILE": "{{ $dataHome }}/ca-certificates/cacert.pem"
{{- else if and (eq .chezmoi.os "linux") (stat "/etc/ssl/certs/ca-certificates.crt") }}
    "AWS_CA_BUNDLE": "/etc/ssl/certs/ca-certificates.crt",
    "CURL_CA_BUNDLE": "/etc/ssl/certs/ca-certificates.crt",
    "DEFAULT_CA_BUNDLE_PATH": "/etc/ssl/certs",
    "REQUESTS_CA_BUNDLE": "/etc/ssl/certs/ca-certificates.crt",
    "SSL_CERT_FILE": "/etc/ssl/certs/ca-certificates.crt"
{{- end }}
  },
  "extensions": {
    "anthropic.claude-code": {
      "autoUpdate": true
    }
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "astral-sh": {
      "source": {
        "source": "github",
        "repo": "astral-sh/claude-code-plugins"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "life-sciences": {
      "source": {
        "source": "github",
        "repo": "anthropics/life-sciences"
      }
    }
  },
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(**)",
      "Grep",
      "ListMcpResourcesTool",
      "Python(*)",
      "Read(**)",
      "ReadMcpResourceTool",
      "Write(**)",
      "mcp__ide__*",
      "mcp__mcp-atlassian__*",
      "mcp__read-website-fast__*",
      "mcp__tooluniverse__*"
    ],
    "defaultMode": "plan",
    "deny": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git merge*)",
      "Bash(git push*)",
      "Bash(git rebase*)",
      "Bash(git reset*)",
      "Bash(rm -rf *)",
      "Edit(**/.env*)",
      "Edit(.env*)",
      "Read(**/.env*)",
      "Read(.env*)",
      "Write(**/.env*)",
      "Write(.env*)"
    ]
  },
  "plansDirectory": "./.claude/plans"
}
