{{- $dpv := env "KOOPA_DRACULA_PRO_VARIANT" -}}
{{- $dpProInstalled := or
    (glob (joinPath .chezmoi.homeDir ".positron" "extensions" "dracula-theme-pro.theme-dracula-pro-*"))
    (glob (joinPath .chezmoi.homeDir ".vscode" "extensions" "dracula-theme-pro.theme-dracula-pro-*"))
-}}
{{- $dpDarkTheme := "Dracula Theme" -}}
{{- $dpLightTheme := "Atom One Light" -}}
{{- if $dpProInstalled -}}
{{-   $dpDarkTheme = "Dracula Pro" -}}
{{-   if and $dpv (ne $dpv "pro") -}}
{{-     $dpDarkTheme = printf "Dracula Pro (%s)" (title $dpv) -}}
{{-   end -}}
{{-   $dpLightTheme = "Dracula Pro (Alucard)" -}}
{{- end -}}
{
  "[python]": {
    "editor.formatOnSave": true
  },
  "[r]": {
    "editor.defaultFormatter": "posit-dev.air-vscode",
    "editor.formatOnSave": true
  },
  "editor.autoClosingBrackets": "never",
  "editor.autoClosingComments": "never",
  "editor.autoClosingDelete": "never",
  "editor.autoClosingOvertype": "never",
  "editor.autoClosingQuotes": "never",
  "editor.autoSurround": "never",
  "editor.codeLens": false,
  "editor.fontFamily": "'JetBrains Mono', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.pasteAs.enabled": false,
  "files.associations": {
    "renv.lock": "json"
  },
{{- if lookPath "git" }}
  "git.path": "{{ lookPath "git" }}",
{{- end }}
  "python.analysis.autoSearchPaths": false,
  "python.analysis.diagnosticsSource": "Pyright",
{{- if lookPath "conda" }}
  "python.condaPath": "{{ lookPath "conda" }}",
{{- end }}
{{- if stat (joinPath .chezmoi.homeDir ".venv" "bin" "python3") }}
  "python.defaultInterpreterPath": "{{ .chezmoi.homeDir }}/.venv/bin/python3",
{{- else if lookPath "python3" }}
  "python.defaultInterpreterPath": "{{ lookPath "python3" }}",
{{- end }}
  "python.experiments.enabled": false,
{{- if lookPath "python3" }}
  "python.pythonPath": "{{ lookPath "python3" }}",
{{- end }}
{{- if lookPath "quarto" }}
  "quarto.path": "{{ lookPath "quarto" }}",
{{- end }}
  "terminal.integrated.defaultProfile.linux": "bash",
{{- if eq .chezmoi.os "darwin" }}
  "terminal.integrated.defaultProfile.osx": "bash",
{{- end }}
  "terminal.integrated.fontFamily": "'JetBrains Mono'",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.fontWeightBold": "bold",
  "terminal.integrated.inheritEnv": true,
{{- if eq .chezmoi.os "darwin" }}
  "terminal.integrated.profiles.osx": {
    "bash": {
      "args": [
        "-il"
      ],
      "icon": "terminal-bash",
      "path": "{{ lookPath "bash" }}"
    },
    "zsh": {
      "args": [
        "-il"
      ],
      "env": {
        "ZDOTDIR": "${env:HOME}/.config/zsh"
      },
      "icon": "terminal-bash",
      "path": "/bin/zsh"
    }
  },
{{- end }}
  "terminal.integrated.stickyScroll.enabled": false,
  "update.mode": "none",
  "update.showReleaseNotes": false,
  "window.autoDetectColorScheme": true,
  "workbench.editor.empty.hint": "hidden",
  "workbench.keybindings.rstudioKeybindings": true,
{{- if eq (env "KOOPA_COLOR_MODE") "light" }}
  "workbench.colorTheme": "{{ $dpLightTheme }}",
{{- else }}
  "workbench.colorTheme": "{{ $dpDarkTheme }}",
{{- end }}
  "workbench.preferredDarkColorTheme": "{{ $dpDarkTheme }}",
  "workbench.preferredLightColorTheme": "{{ $dpLightTheme }}",
  "workbench.startupEditor": "newUntitledFile"
}
