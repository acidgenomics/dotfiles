# Koopa activation for fish shell.
set -l __koopa_data_home
if set -q XDG_DATA_HOME
    set __koopa_data_home $XDG_DATA_HOME
else
    set __koopa_data_home "$HOME/.local/share"
end
set -l __koopa_activate "$__koopa_data_home/koopa/activate.fish"
if test -r "$__koopa_activate"
    source "$__koopa_activate"
end

# FZF color scheme — set after activation so we override koopa's generic dark/light.
# Dracula Pro colors (if installed) are sourced from a generated file written by
# the koopa dotfiles install script; otherwise fall back to free Dracula / One Light.
set -l _koopa_fzf_colors
if test "{{ env "KOOPA_COLOR_MODE" }}" = light
    set _koopa_fzf_colors (test -n "$XDG_CONFIG_HOME" && echo "$XDG_CONFIG_HOME" || echo "$HOME/.config")/fish/dracula-pro-alucard-colors.fish
else
    set _koopa_fzf_colors (test -n "$XDG_CONFIG_HOME" && echo "$XDG_CONFIG_HOME" || echo "$HOME/.config")/fish/dracula-pro-colors.fish
end
if test -f $_koopa_fzf_colors
    source $_koopa_fzf_colors
else
{{ if eq (env "KOOPA_COLOR_MODE") "dark" -}}
set -g fish_color_normal f8f8f2
set -g fish_color_command 50fa7b
set -g fish_color_keyword 8be9fd
set -g fish_color_quote f1fa8c
set -g fish_color_redirection ff79c6
set -g fish_color_end ff79c6
set -g fish_color_error ff5555
set -g fish_color_param f8f8f2
set -g fish_color_comment 6272a4
set -g fish_color_operator ff79c6
set -g fish_color_escape 8be9fd
set -g fish_color_autosuggestion 6272a4
set -g fish_color_selection --background=44475a
set -g fish_color_search_match --background=44475a
set -g fish_color_cwd 50fa7b
set -g fish_color_cwd_root ff5555
set -gx FZF_DEFAULT_OPTS '--color=fg:#f8f8f2,bg:#282a36,hl:#bd93f9 --color=fg+:#f8f8f2,bg+:#44475a,hl+:#bd93f9 --color=info:#ffb86c,prompt:#50fa7b,pointer:#ff79c6 --color=marker:#ff79c6,spinner:#ffb86c,header:#6272a4'
{{- else -}}
set -gx FZF_DEFAULT_OPTS '--color=fg:#383a42,bg:#fafafa,hl:#a626a4 --color=fg+:#383a42,bg+:#e8e8e8,hl+:#a626a4 --color=info:#986801,prompt:#50a14f,pointer:#a626a4 --color=marker:#a626a4,spinner:#986801,header:#a0a1a7'
{{- end }}
end
