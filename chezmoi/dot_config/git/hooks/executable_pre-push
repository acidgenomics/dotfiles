#!/bin/sh
# Global pre-push guard: refuse to push commits authored/committed with a
# corporate identity to a remote not in the corporate allowlist.
#
# No-op unless koopa.corp* config keys are set (set only by the private
# config-corp file). On non-corp machines this hook exits 0 immediately.

remote_url="$2"
z=0000000000000000000000000000000000000000

domains=$(git config --get-all koopa.corpEmailDomains)
allow=$(git config --get-all koopa.corpRemoteAllowlist)

# Not a corp-configured machine — safe no-op.
[ -n "$domains" ] || exit 0

# Is the destination remote permitted to receive corp-identity commits?
remote_allowed=0
for a in $allow; do
    case "$remote_url" in
        *"$a"*) remote_allowed=1 ;;
    esac
done

# Build an alternation pattern for grep from the domain list.
dpat=$(printf '%s' "$domains" | tr ' \n' '|' | sed 's/|*$//; s/\./\\./g')

found_corp=0
while read -r lref loid rref roid; do
    [ "$loid" = "$z" ] && continue
    if [ "$roid" = "$z" ]; then
        range="$loid --not --remotes"
    else
        range="$roid..$loid"
    fi
    if git log --format='%ae%n%ce' $range 2>/dev/null | grep -qiE "@($dpat)\$"; then
        found_corp=1
    fi
done

if [ "$found_corp" = 1 ] && [ "$remote_allowed" = 0 ]; then
    echo "ERROR (koopa pre-push guard): refusing to push commits authored with a" >&2
    echo "  corporate identity ($domains) to a non-corporate remote:" >&2
    echo "    $remote_url" >&2
    echo "  Allowed corporate remotes must contain: $allow" >&2
    echo "  Fix author identity (git commit --amend --reset-author / git rebase)" >&2
    echo "  or push to an allowed remote." >&2
    exit 1
fi
exit 0
