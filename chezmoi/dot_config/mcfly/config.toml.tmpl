{{- $dpProInstalled := stat (joinPath .chezmoi.homeDir ".local/share/dracula-pro") -}}
# """
# McFly configuration
#
# @note Updated 2026-06-01.
#
# The following colors are supported, according to README:
#
# | Light       | Dark           |
# | :---------- | :------------- |
# | `dark_grey` | `black`        |
# | `red`       | `dark_red`     |
# | `green`     | `dark_green`   |
# | `yellow`    | `dark_yellow`  |
# | `blue`      | `dark_blue`    |
# | `magenta`   | `dark_magenta` |
# | `cyan`      | `dark_cyan`    |
# | `white`     | `grey`         |
#
# @seealso
# - https://github.com/cantino/mcfly/pull/319
# - https://github.com/cantino/mcfly/pull/343
# - https://github.com/cantino/mcfly/pull/405
# - Alacritty rendering issues:
#   https://github.com/cantino/mcfly/issues/316
# """

[colors]

[colors.menubar]
bg = "blue"
fg = "white"

[colors.darkmode]
prompt = "green"
timing = "cyan"
results_fg = "white"
results_bg = "black"
results_hl = "magenta"
results_selection_fg = "white"
results_selection_bg = "dark_blue"
results_selection_hl = "cyan"

{{- if $dpProInstalled }}
[colors.lightmode]
prompt = "dark_green"
timing = "dark_cyan"
results_fg = "grey"
results_bg = "black"
results_hl = "dark_blue"
results_selection_fg = "dark_grey"
results_selection_bg = "dark_blue"
results_selection_hl = "dark_grey"
{{- end }}
