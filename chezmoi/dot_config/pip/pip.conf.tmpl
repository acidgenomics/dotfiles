[global]
{{- $dataHome := env "XDG_DATA_HOME" | default (joinPath .chezmoi.homeDir ".local/share") -}}
{{- if stat (joinPath $dataHome "ca-certificates" "cacert.pem") }}
cert={{ $dataHome }}/ca-certificates/cacert.pem
{{- else if and (eq .chezmoi.os "linux") (stat "/etc/ssl/certs/ca-certificates.crt") }}
cert=/etc/ssl/certs/ca-certificates.crt
{{- end }}
disable-pip-version-check=True
no-cache-dir=True
no-warn-script-location=True
progress-bar=on
require-virtualenv=True
timeout=120
upgrade=True
