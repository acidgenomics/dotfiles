{{- $dataHome := env "XDG_DATA_HOME" | default (joinPath .chezmoi.homeDir ".local/share") -}}
{{- if stat (joinPath $dataHome "ca-certificates" "cacert.pem") }}
cafile={{ $dataHome }}/ca-certificates/cacert.pem
{{- else if and (eq .chezmoi.os "linux") (stat "/etc/ssl/certs/ca-certificates.crt") }}
cafile=/etc/ssl/certs/ca-certificates.crt
{{- end }}
{{- if env "HTTPS_PROXY" }}
https-proxy={{ env "HTTPS_PROXY" }}
{{- end }}
{{- if env "HTTP_PROXY" }}
proxy={{ env "HTTP_PROXY" }}
{{- end }}
update-notifier=false
