    }
    xml = dark_xml
    xml = xml.replace('name="Dracula Pro"', 'name="Dracula Pro Alucard"')
    xml = xml.replace('parent_scheme="Darcula"', 'parent_scheme="Default"')
    for dark_hex, light_hex in color_map.items():
        xml = re.sub(
            re.escape(dark_hex),
            light_hex,
            xml,
            flags=re.IGNORECASE,
        )
    return json.dumps(theme, indent=2), xml


def _configure_jetbrains(home: str) -> None:
    """Configure JetBrains IDEs with Dracula Pro theme and sync with OS."""
    import glob as _glob
    if not is_macos():
        return
    dp_dir = os.path.join(xdg_data_home(), "dracula-pro")
    has_dracula_pro = os.path.isdir(dp_dir)
    jetbrains_base = os.path.join(home, "Library", "Application Support", "JetBrains")
    if not os.path.isdir(jetbrains_base):
        return
    # Find all JetBrains IDE settings directories
    ide_dirs = sorted(
        _glob.glob(os.path.join(jetbrains_base, "PyCharm[0-9]*"))
        + _glob.glob(os.path.join(jetbrains_base, "IntelliJIdea*"))
        + _glob.glob(os.path.join(jetbrains_base, "DataGrip*"))
        + _glob.glob(os.path.join(jetbrains_base, "WebStorm*"))
        + _glob.glob(os.path.join(jetbrains_base, "GoLand*"))
        + _glob.glob(os.path.join(jetbrains_base, "RustRover*"))
    )
    if not ide_dirs:
        return

    # Generate Alucard theme if Dracula Pro is available
    alucard_theme_json: str | None = None
    alucard_xml: str | None = None
    if has_dracula_pro:
        result = _generate_pycharm_alucard_theme(dp_dir)
        if result:
            alucard_theme_json, alucard_xml = result

    # themeIds: dark from the official plugin.xml; Alucard from koopa's local plugin
    _DP_DARK_THEME_ID = "171dce76-a3c5-4429-91af-41cf86094740"
    _DP_ALUCARD_THEME_ID = "a71dce76-a3c5-4429-91af-41cf86094740"
    # Built-in fallback themeIds (no Pro source available)
    _DARCULA_THEME_ID = "Darcula"
    _LIGHT_THEME_ID = "ExperimentalLight"

    # Staged official plugin zip (symlinked by _configure_dracula_pro_post)
    vsix_path = os.path.join(xdg_config_home(), "koopa", "jetbrains-theme", "dracula-pro.zip")
    has_plugin_zip = has_dracula_pro and os.path.isfile(vsix_path)

    # Current OS appearance — set authoritatively in main() before this runs
    is_light = os.environ.get("KOOPA_COLOR_MODE", "dark") == "light"

    for ide_dir in ide_dirs:
        options_dir = os.path.join(ide_dir, "options")
        os.makedirs(options_dir, exist_ok=True)
        plugins_dir = os.path.join(ide_dir, "plugins")

        newly_installed = False

        if has_plugin_zip:
            # Install official dark plugin if absent
            dark_plugin_dir = os.path.join(plugins_dir, "dracula-pro")
            if not os.path.isdir(dark_plugin_dir):
                os.makedirs(plugins_dir, exist_ok=True)
                with zipfile.ZipFile(vsix_path) as zf:
                    zf.extractall(plugins_dir)
                newly_installed = True

        if alucard_theme_json and alucard_xml:
            # Build the koopa Alucard plugin jar (pure-resource, no .class files)
            alucard_plugin_dir = os.path.join(plugins_dir, "dracula-pro-alucard", "lib")
            os.makedirs(alucard_plugin_dir, exist_ok=True)
            alucard_jar_path = os.path.join(alucard_plugin_dir, "dracula-pro-alucard.jar")
            plugin_xml = (
                '<idea-plugin>\n'
                '  <idea-version since-build="191"/>\n'
                '  <id>com.koopa.dracula-pro-alucard</id>\n'
                '  <name>Dracula Pro Alucard</name>\n'
                '  <version>1.0.0</version>\n'
                '  <vendor>koopa</vendor>\n'
                '  <depends>com.intellij.modules.lang</depends>\n'
                '  <extensions defaultExtensionNs="com.intellij">\n'
                f'    <themeProvider id="{_DP_ALUCARD_THEME_ID}"'
                ' path="/themes/DraculaProAlucard.theme.json"/>\n'
                '  </extensions>\n'
                '</idea-plugin>\n'
            )
            with zipfile.ZipFile(alucard_jar_path, "w", zipfile.ZIP_DEFLATED) as jar:
                jar.writestr("META-INF/MANIFEST.MF", "Manifest-Version: 1.0\n")
                jar.writestr("META-INF/plugin.xml", plugin_xml)
                jar.writestr("themes/DraculaProAlucard.theme.json", alucard_theme_json)
                jar.writestr("themes/DraculaProAlucard.xml", alucard_xml)
            newly_installed = True

        # Write laf.xml — always rewrite so koopa can correct stale IDE defaults.
        # laf.xml holds only LafManager theme wiring; koopa owns this file.
        laf_path = os.path.join(options_dir, "laf.xml")
        if has_plugin_zip and alucard_theme_json:
            dark_id = _DP_DARK_THEME_ID
            light_id = _DP_ALUCARD_THEME_ID
            dark_scheme = "Dracula Pro"
            light_scheme = "Dracula Pro Alucard"
        else:
            dark_id = _DARCULA_THEME_ID
            light_id = _LIGHT_THEME_ID
            dark_scheme = "Darcula"
            light_scheme = "Default"
        active_id = light_id if is_light else dark_id
        laf_content = (
            '<application>\n'
            '  <component name="LafManager" autodetect="true">\n'
            f'    <laf themeId="{active_id}" />\n'
            f'    <preferred-light-laf themeId="{light_id}" />\n'
            f'    <preferred-dark-laf themeId="{dark_id}" />\n'
            f'    <preferred-light-editor-scheme editorSchemeId="{light_scheme}" />\n'
            f'    <preferred-dark-editor-scheme editorSchemeId="{dark_scheme}" />\n'
            '  </component>\n'
            '</application>\n'
        )
        with open(laf_path, "w") as fh:
            fh.write(laf_content)

        # Merge ide.mac.appearance.mode=system into ide.general.xml
        general_xml_path = os.path.join(options_dir, "ide.general.xml")
        if os.path.isfile(general_xml_path):
            with open(general_xml_path) as fh:
                content = fh.read()
            if "ide.mac.appearance.mode" not in content:
                content = content.replace(
                    '  <component name="Registry">',
                    '  <component name="Registry">\n'
                    '    <entry key="ide.mac.appearance.mode" value="system" />',
                )
                with open(general_xml_path, "w") as fh:
                    fh.write(content)
        else:
            with open(general_xml_path, "w") as fh:
                fh.write(
                    '<application>\n'
                    '  <component name="Registry">\n'
                    '    <entry key="ide.mac.appearance.mode" value="system" />\n'
                    '  </component>\n'
                    '</application>\n'
                )

        if newly_installed:
            print(
                f"JetBrains ({os.path.basename(ide_dir)}): installed Dracula Pro plugins.\n"
                "  Quit PyCharm (if running) and restart it to apply the theme.\n"
                "  On first launch you may see a third-party plugin consent prompt — "
                "click Enable."
            )


def _configure_koopa_color_mode_sync(home: str) -> None:
    """Install the koopa-color-mode-sync VS Code extension."""
    ext_src_dir = os.path.join(str(_PREFIX), "etc", "vscode", "koopa-color-mode-sync")
    vsix = os.path.join(ext_src_dir, "koopa-color-mode-sync-0.1.0.vsix")
    if not os.path.isfile(vsix):
        return
    with zipfile.ZipFile(vsix) as zf:
        pkg = json.loads(zf.read("extension/package.json"))
    publisher = pkg["publisher"]
    ext_name = pkg["name"]
    dir_prefix = f"{publisher}.{ext_name}-"
    targets: list[tuple[str, str]] = []
    code = shutil.which("code")
    if code:
        targets.append((code, os.path.join(home, ".vscode", "extensions")))
    code_server = shutil.which("code-server")
    if code_server:
        targets.append((
            code_server,
            os.path.join(home, ".local", "share", "code-server", "extensions"),
        ))
    positron = _positron_cli(home)
    if positron:
        targets.append((positron, _positron_ext_dir(home)))
    cursor = shutil.which("cursor")
    if cursor:
        targets.append((cursor, _cursor_ext_dir(home)))
    antigravity = shutil.which("antigravity")
    if antigravity:
        targets.append((antigravity, _antigravity_ext_dir(home)))
    for binary, ext_dir in targets:
        _install_vscode_extension(
            vsix, dir_prefix, ext_dir, binary,
            "koopa-color-mode-sync extension",
        )


def _configure_dracula_pro(home: str, xdg_data: str) -> None:
    """Pre-chezmoi: vim pack, VS Code extension install."""
    dp_dir = os.path.join(xdg_data, "dracula-pro")
    if not os.path.isdir(dp_dir):
        return
    # Vim/Neovim: symlink theme pack so nvim detects it at runtime.
    vim_src = os.path.join(dp_dir, "themes", "vim")
    vim_themes = os.path.join(home, ".vim", "pack", "theme", "start")
    mkdir(vim_themes)
    if os.path.isdir(vim_src):
        ln(vim_src, os.path.join(vim_themes, "dracula_pro"))
    # VS Code / Positron: install VSIX if missing or version doesn't match.
    vsix = os.path.join(
        dp_dir, "themes", "visual-studio-code", "dracula-pro.vsix"
    )
    if os.path.isfile(vsix):
        dp_prefix = "dracula-theme-pro.theme-dracula-pro-"
        code = shutil.which("code")
        if code:
            _install_vscode_extension(
                vsix, dp_prefix,
                os.path.join(home, ".vscode", "extensions"),
                code, "Dracula Pro VS Code extension",
            )
        positron = _positron_cli(home)
        if positron:
            _install_vscode_extension(
                vsix, dp_prefix,
                _positron_ext_dir(home),
                positron, "Dracula Pro Positron extension",
            )
        cursor = shutil.which("cursor")
        if cursor:
            _install_vscode_extension(
                vsix, dp_prefix,
                _cursor_ext_dir(home),
                cursor, "Dracula Pro Cursor extension",
            )
        antigravity = shutil.which("antigravity")
        if antigravity:
            _install_vscode_extension(
                vsix, dp_prefix,
                _antigravity_ext_dir(home),
                antigravity, "Dracula Pro Antigravity extension",
            )


def _configure_dracula_pro_post(home: str, xdg_data: str) -> None:
    """Post-chezmoi: all apps that need chezmoi-created dirs to exist first."""
    dp_dir = os.path.join(xdg_data, "dracula-pro")
    if not os.path.isdir(dp_dir):
        return
    variant = os.environ.get("KOOPA_DRACULA_PRO_VARIANT", "pro")
    # Ghostty: symlink all variant theme files into ~/.config/ghostty/themes/.
    ghostty_themes = os.path.join(home, ".config", "ghostty", "themes")
    ghostty_src = os.path.join(dp_dir, "themes", "ghostty")
    if os.path.isdir(ghostty_src):
        mkdir(ghostty_themes)
        for src_name, dest_name in _DRACULA_VARIANT_NAMES.items():
            src = os.path.join(ghostty_src, src_name)
            dest = os.path.join(ghostty_themes, dest_name)
            if os.path.isfile(src):
                ln(src, dest)
    # Alacritty: symlink selected dark variant and alucard light variant.
    alacritty_themes = os.path.join(home, ".config", "alacritty", "themes")
    alacritty_src_dir = os.path.join(dp_dir, "themes", "alacritty", "themes")
    if os.path.isdir(alacritty_themes) and os.path.isdir(alacritty_src_dir):
        variant_file = (
            "dracula-pro.toml"
            if variant == "pro"
            else f"dracula-pro-{variant}.toml"
        )
        dark_src = os.path.join(alacritty_src_dir, variant_file)
        if os.path.isfile(dark_src):
            ln(dark_src, os.path.join(alacritty_themes, "dracula.toml"))
        alucard_src = os.path.join(alacritty_src_dir, "dracula-pro-alucard.toml")
        if os.path.isfile(alucard_src):
            ln(alucard_src, os.path.join(alacritty_themes, "one-light.toml"))
    # Emacs/Doom: symlink all variant .el files into ~/.config/doom/themes/.
    doom_themes = os.path.join(home, ".config", "doom", "themes")
    emacs_src = os.path.join(dp_dir, "themes", "emacs")
    if os.path.isdir(emacs_src):
        mkdir(doom_themes)
        for el_file in os.listdir(emacs_src):
            if el_file.endswith(".el"):
                ln(
                    os.path.join(emacs_src, el_file),
                    os.path.join(doom_themes, el_file),
                )
    # iTerm: symlink selected variant into etc/iterm/ staging location.
    iterm_src_name = _dracula_iterm_name(variant)
    iterm_src = os.path.join(dp_dir, "themes", "iterm", iterm_src_name)
    if os.path.isfile(iterm_src):
        iterm_dest = os.path.join(
            str(_PREFIX), "etc", "iterm", "dracula-pro.itermcolors"
        )
        ln(iterm_src, iterm_dest)
    # Terminal.app: symlink selected variant into etc/terminal/ staging location.
    terminal_src_name = _dracula_terminal_name(variant)
    terminal_src = os.path.join(
        dp_dir, "themes", "terminal-app", terminal_src_name
    )
    if os.path.isfile(terminal_src):
        terminal_dest = os.path.join(
            str(_PREFIX), "etc", "terminal", "dracula-pro.terminal"
        )
        ln(terminal_src, terminal_dest)
    # Xcode: symlink all variant .xccolortheme files into Xcode's theme dir.
    if is_macos():
        xcode_themes = os.path.join(
            home, "Library", "Developer", "Xcode", "UserData", "FontAndColorThemes"
        )
        xcode_src = os.path.join(dp_dir, "themes", "xcode")
        if os.path.isdir(xcode_src):
            mkdir(xcode_themes)
            for f in os.listdir(xcode_src):
                if f.endswith(".xccolortheme"):
                    ln(
                        os.path.join(xcode_src, f),
                        os.path.join(xcode_themes, f),
                    )
    # Zed: symlink theme JSON into ~/.config/zed/themes/.
    zed_themes = os.path.join(home, ".config", "zed", "themes")
    zed_src = os.path.join(dp_dir, "themes", "zed", "dracula_pro.json")
    if os.path.isfile(zed_src):
        mkdir(zed_themes)
        ln(zed_src, os.path.join(zed_themes, "dracula_pro.json"))
    # Firefox: symlink all variant .xpi dirs into ~/.config/koopa/firefox-themes/.
    firefox_staging = os.path.join(xdg_config_home(), "koopa", "firefox-themes")
    firefox_src = os.path.join(dp_dir, "themes", "firefox")
    if os.path.isdir(firefox_src):
        mkdir(firefox_staging)
        for entry in os.listdir(firefox_src):
            src = os.path.join(firefox_src, entry)
            if os.path.isdir(src):
                ln(src, os.path.join(firefox_staging, entry))
    # Google Chrome: symlink variant dir into ~/.config/koopa/chrome-themes/.
    chrome_staging = os.path.join(xdg_config_home(), "koopa", "chrome-themes")
    chrome_src_dir = os.path.join(dp_dir, "themes", "google-chrome")
    if os.path.isdir(chrome_src_dir):
        mkdir(chrome_staging)
        for entry in os.listdir(chrome_src_dir):
            src = os.path.join(chrome_src_dir, entry)
            if os.path.isdir(src):
                ln(src, os.path.join(chrome_staging, entry))
    # Hyper: symlink variant .js file into ~/.config/koopa/hyper-themes/.
    hyper_staging = os.path.join(xdg_config_home(), "koopa", "hyper-themes")
    hyper_variants = os.path.join(dp_dir, "themes", "hyper", "variants")
    if os.path.isdir(hyper_variants):
        mkdir(hyper_staging)
        for f in os.listdir(hyper_variants):
            if f.endswith(".js"):
                ln(
                    os.path.join(hyper_variants, f),
                    os.path.join(hyper_staging, f),
                )
    # JetBrains: symlink plugin zip into ~/.config/koopa/jetbrains-theme/.
    jetbrains_staging = os.path.join(
        xdg_config_home(), "koopa", "jetbrains-theme"
    )
    jetbrains_src = os.path.join(
        dp_dir, "themes", "jetbrains", "dracula-pro.zip"
    )
    if os.path.isfile(jetbrains_src):
        mkdir(jetbrains_staging)
        ln(
            jetbrains_src,
            os.path.join(jetbrains_staging, "dracula-pro.zip"),
        )
    # Windows Terminal: symlink all variant JSON files into staging dir.
    wt_staging = os.path.join(
        xdg_config_home(), "koopa", "windows-terminal-themes"
    )
    wt_src = os.path.join(dp_dir, "themes", "windows-terminal")
    if os.path.isdir(wt_src):
        mkdir(wt_staging)
        for f in os.listdir(wt_src):
            if f.endswith(".json"):
                ln(
                    os.path.join(wt_src, f),
                    os.path.join(wt_staging, f),
                )
    # Insomnia: symlink plugin dir if Insomnia is installed.
    insomnia_plugins = os.path.join(
        home, "Library", "Application Support", "Insomnia", "plugins"
    )
    insomnia_src = os.path.join(dp_dir, "themes", "insomnia", "dracula-pro")
    if os.path.isdir(insomnia_src) and os.path.isdir(insomnia_plugins):
        ln(insomnia_src, os.path.join(insomnia_plugins, "dracula-pro"))
    # Sublime Text: symlink themes dir as a Packages entry.
    sublime_packages = os.path.join(
        home, "Library", "Application Support", "Sublime Text", "Packages"
    )
    sublime_src = os.path.join(dp_dir, "themes", "sublime")
    if os.path.isdir(sublime_src) and os.path.isdir(sublime_packages):
        ln(sublime_src, os.path.join(sublime_packages, "Dracula Pro"))
    # JetBrains Fleet: symlink JSON themes dir if Fleet is installed.
    fleet_themes = os.path.join(home, ".fleet", "themes")
    fleet_src = os.path.join(dp_dir, "themes", "jetbrains", "experimental")
    if os.path.isdir(fleet_src) and os.path.isdir(os.path.join(home, ".fleet")):
        mkdir(fleet_themes)
        for f in os.listdir(fleet_src):
            if f.endswith(".json"):
                ln(
                    os.path.join(fleet_src, f),
                    os.path.join(fleet_themes, f),
                )
    # gnome-terminal: run variant install.sh non-interactively (Linux only).
    if not is_macos():
        gnome_install_sh = os.path.join(
            dp_dir, "themes", "gnome-terminal", variant, "install.sh"
        )
        if os.path.isfile(gnome_install_sh):
            subprocess.run(
                ["bash", gnome_install_sh],
                capture_output=True,
            )
    # Notepad++: stage XML files for manual install.
    notepad_staging = os.path.join(xdg_config_home(), "koopa", "notepad-themes")
    notepad_src = os.path.join(dp_dir, "themes", "notepad-plus-plus")
    if os.path.isdir(notepad_src):
        mkdir(notepad_staging)
        for f in os.listdir(notepad_src):
            if f.endswith(".xml"):
                ln(
                    os.path.join(notepad_src, f),
                    os.path.join(notepad_staging, f),
                )
    # Raycast: stage JSON files for manual import.
    raycast_staging = os.path.join(xdg_config_home(), "koopa", "raycast-themes")
    raycast_src = os.path.join(dp_dir, "themes", "raycast", "json-files")
    if os.path.isdir(raycast_src):
        mkdir(raycast_staging)
        for f in os.listdir(raycast_src):
            if f.endswith(".json"):
                ln(
                    os.path.join(raycast_src, f),
                    os.path.join(raycast_staging, f),
                )
    # Tmux: generate Pro dark.conf and Alucard light.conf, override chezmoi files.
    tmux_colors = os.path.join(home, ".config", "tmux", "colors")
    if os.path.isdir(tmux_colors):
        pro_conf = _generate_tmux_dracula_pro_conf(dp_dir, variant)
        if pro_conf:
            with open(os.path.join(tmux_colors, "dark.conf"), "w") as fh:
                fh.write(pro_conf)
        alucard_conf = _generate_tmux_alucard_conf(dp_dir)
        if alucard_conf:
            with open(os.path.join(tmux_colors, "light.conf"), "w") as fh:
                fh.write(alucard_conf)
    # Zsh: generate palette files sourced at runtime by .zshrc.
    zsh_config = os.path.join(home, ".config", "zsh")
    if os.path.isdir(zsh_config):
        zsh_palette = _generate_zsh_dracula_pro_palette(dp_dir, variant)
        if zsh_palette:
            with open(os.path.join(zsh_config, "dracula-pro-colors.zsh"), "w") as fh:
                fh.write(zsh_palette)
        alucard_palette = _generate_zsh_dracula_pro_palette(dp_dir, "alucard")
        if alucard_palette:
            with open(
                os.path.join(zsh_config, "dracula-pro-alucard-colors.zsh"), "w"
            ) as fh:
                fh.write(alucard_palette)
    # Kitty: generate Dracula Pro theme conf files for selected variant and Alucard.
    kitty_themes = os.path.join(home, ".config", "kitty", "themes")
    if os.path.isdir(kitty_themes):
        dark_kitty_conf = _generate_kitty_dracula_pro_conf(dp_dir, variant)
        if dark_kitty_conf:
            with open(os.path.join(kitty_themes, "dracula-pro.conf"), "w") as fh:
                fh.write(dark_kitty_conf)
        alucard_kitty_conf = _generate_kitty_dracula_pro_conf(dp_dir, "alucard")
        if alucard_kitty_conf:
            with open(os.path.join(kitty_themes, "dracula-pro-alucard.conf"), "w") as fh:
                fh.write(alucard_kitty_conf)
    # WezTerm: generate Dracula Pro TOML color scheme files in ~/.config/wezterm/colors/.
    wezterm_config = os.path.join(home, ".config", "wezterm")
    if os.path.isdir(wezterm_config):
        wezterm_colors = os.path.join(wezterm_config, "colors")
        mkdir(wezterm_colors)
        dark_wez = _generate_wezterm_dracula_pro_toml(dp_dir, variant)
        if dark_wez:
            with open(os.path.join(wezterm_colors, "Dracula Pro.toml"), "w") as fh:
                fh.write(dark_wez)
        alucard_wez = _generate_wezterm_dracula_pro_toml(dp_dir, "alucard")
        if alucard_wez:
            with open(os.path.join(wezterm_colors, "Dracula Pro Alucard.toml"), "w") as fh:
                fh.write(alucard_wez)
    # Atuin: generate Dracula Pro theme TOML files in ~/.config/atuin/themes/.
    atuin_themes = os.path.join(home, ".config", "atuin", "themes")
    if os.path.isdir(os.path.join(home, ".config", "atuin")):
        os.makedirs(atuin_themes, exist_ok=True)
        dark_atuin = _generate_atuin_dracula_pro_toml(dp_dir, variant)
        if dark_atuin:
            with open(os.path.join(atuin_themes, "dracula-pro.toml"), "w") as fh:
                fh.write(dark_atuin)
        alucard_atuin = _generate_atuin_dracula_pro_toml(dp_dir, "alucard")
        if alucard_atuin:
            with open(os.path.join(atuin_themes, "dracula-pro-alucard.toml"), "w") as fh:
                fh.write(alucard_atuin)
    # Bat: symlink Pro .tmTheme files into ~/.config/bat/themes/ and rebuild cache.
    _tmtheme_name_map = {
        "pro": "Dracula Pro.tmTheme",
        "blade": "Dracula Pro (Blade).tmTheme",
        "buffy": "Dracula Pro (Buffy).tmTheme",
        "lincoln": "Dracula Pro (Lincoln).tmTheme",
        "morbius": "Dracula Pro (Morbius).tmTheme",
        "van-helsing": "Dracula Pro (Van Helsing).tmTheme",
        "alucard": "Dracula Pro (Alucard).tmTheme",
    }
    bat_themes = os.path.join(home, ".config", "bat", "themes")
    sublime_src = os.path.join(dp_dir, "themes", "sublime")
    if os.path.isdir(sublime_src):
        os.makedirs(bat_themes, exist_ok=True)
        dark_fname = _tmtheme_name_map.get(variant, "Dracula Pro.tmTheme")
        dark_tmtheme = os.path.join(sublime_src, dark_fname)
        if os.path.isfile(dark_tmtheme):
            ln(dark_tmtheme, os.path.join(bat_themes, "Dracula Pro.tmTheme"))
        alucard_tmtheme = os.path.join(sublime_src, "Dracula Pro (Alucard).tmTheme")
        if os.path.isfile(alucard_tmtheme):
            ln(alucard_tmtheme, os.path.join(bat_themes, "Dracula Pro (Alucard).tmTheme"))
        bat_bin = shutil.which("bat")
        if bat_bin:
            subprocess.run([bat_bin, "cache", "--build"], capture_output=True)
    # RStudio: generate .rstheme from .tmTheme source (no Pro colors in repo).
    rstudio_themes = os.path.join(home, ".config", "rstudio", "themes")
    template_rstheme = os.path.join(
        str(_PREFIX), "chezmoi", "dot_config", "rstudio", "themes", "dracula.rstheme"
    )
    if os.path.isdir(rstudio_themes) and os.path.isfile(template_rstheme):
        # Generate the selected dark variant.
        dark_css = _generate_rstudio_rstheme(dp_dir, variant, template_rstheme)
        if dark_css:
            with open(os.path.join(rstudio_themes, "dracula-pro.rstheme"), "w") as fh:
                fh.write(dark_css)
        # Always generate Alucard (light) variant as well.
        alucard_css = _generate_rstudio_rstheme(dp_dir, "alucard", template_rstheme)
        if alucard_css:
            with open(
                os.path.join(rstudio_themes, "dracula-pro-alucard.rstheme"), "w"
            ) as fh:
                fh.write(alucard_css)
    # BBEdit 16 is sandboxed — TCC blocks writes to ~/Library/Application Support/BBEdit/.
    # Generate .bbColorScheme files into the source dir; user opens them in BBEdit to install.
    # If BBEdit iCloud sync is enabled, also write directly into that Color Schemes folder.
    if is_macos():
        bbedit_out = os.path.join(dp_dir, "themes", "bbedit")
        os.makedirs(bbedit_out, exist_ok=True)
        dark_scheme = _generate_bbedit_dracula_pro(dp_dir, variant)
        alucard_scheme = _generate_bbedit_dracula_pro(dp_dir, "alucard")
        bbedit_icloud = os.path.join(
            home,
            "Library",
            "Mobile Documents",
            "iCloud~com~barebones~bbedit",
            "Documents",
            "Application Support",
            "Color Schemes",
        )
        newly_created = False
        for scheme, name in (
            (dark_scheme, "Dracula Pro.bbColorScheme"),
            (alucard_scheme, "Dracula Pro Alucard.bbColorScheme"),
        ):
            if not scheme:
                continue
            dest = os.path.join(bbedit_out, name)
            if not os.path.isfile(dest):
                newly_created = True
            with open(dest, "w") as fh:
                fh.write(scheme)
            if os.path.isdir(bbedit_icloud):
                with open(os.path.join(bbedit_icloud, name), "w") as fh:
                    fh.write(scheme)
        if newly_created:
            if os.path.isdir(bbedit_icloud):
                print("BBEdit: color schemes installed via iCloud sync.")
            else:
                print(
                    f"BBEdit: open .bbColorScheme files from {bbedit_out} in BBEdit to install."
                )


def _parse_ghostty_palette(dp_dir: str, variant: str) -> dict[str, str] | None:
    """Parse hex colors from a Ghostty theme file. Returns dict of role->hex."""
    theme_file = os.path.join(dp_dir, "themes", "ghostty", variant)
    if not os.path.isfile(theme_file):
        return None
    ansi: dict[int, str] = {}
    extras: dict[str, str] = {}
    with open(theme_file) as fh:
        for line in fh:
            line = line.strip()
            if line.startswith("palette = "):
                _, rest = line.split("=", 1)
                idx_str, color = rest.strip().split("=", 1)
                ansi[int(idx_str.strip())] = color.strip()
            elif "=" in line and not line.startswith("#"):
                key, val = line.split("=", 1)
                extras[key.strip()] = val.strip()
    if not ansi:
        return None
    return {
        "foreground":   extras.get("foreground", ansi.get(7, "#F8F8F2")),
        "selection_bg": extras.get("selection-background", ansi.get(8, "#44475a")),
        "red":          ansi.get(1, "#ff5555"),
        "green":        ansi.get(2, "#50fa7b"),
        "yellow":       ansi.get(3, "#f1fa8c"),
        "blue":         ansi.get(4, "#bd93f9"),
        "magenta":      ansi.get(5, "#ff79c6"),
        "cyan":         ansi.get(6, "#8be9fd"),
        "black":        ansi.get(0, "#282a36"),
        "black_bright": ansi.get(8, "#000000"),
        "red_bright":   ansi.get(9, "#000000"),
        "green_bright": ansi.get(10, "#000000"),
        "yellow_bright": ansi.get(11, "#000000"),
        "blue_bright":  ansi.get(12, "#000000"),
        "magenta_bright": ansi.get(13, "#000000"),
        "cyan_bright":  ansi.get(14, "#000000"),
        "comment":      ansi.get(8, "#000000"),
    }


def _generate_tmux_dracula_pro_conf(dp_dir: str, variant: str) -> str | None:
    """Generate a tmux dark.conf with Dracula Pro colors for the given variant."""
    p = _parse_ghostty_palette(dp_dir, variant)
    if not p:
        return None
    return f"""\
# Dracula Pro color palette ({variant}).
# Auto-generated by koopa dotfiles install from local Dracula Pro source.

# Standard ANSI colors.
%hidden black='{p["black"]}'
%hidden black_bright='{p["black_bright"]}'
%hidden red='{p["red"]}'
%hidden red_bright='{p["red_bright"]}'
%hidden green='{p["green"]}'
%hidden green_bright='{p["green_bright"]}'
%hidden yellow='{p["yellow"]}'
%hidden yellow_bright='{p["yellow_bright"]}'
%hidden blue='{p["blue"]}'
%hidden blue_bright='{p["blue_bright"]}'
%hidden magenta='{p["magenta"]}'
%hidden magenta_bright='{p["magenta_bright"]}'
%hidden cyan='{p["cyan"]}'
%hidden cyan_bright='{p["cyan_bright"]}'
%hidden white='{p["foreground"]}'
%hidden white_bright='#ffffff'

# Additional accent colors.
%hidden bright_purple='{p["blue"]}'
%hidden dark_purple='{p["black"]}'
%hidden muted_purple='{p["comment"]}'

set-option -g message-style "bg=${{dark_purple}},fg=${{white}}"
set-option -g pane-active-border-style "fg=${{bright_purple}}"
set-option -g pane-border-style "fg=${{dark_purple}}"
set-option -g status-left "#[bg=#{{bright_purple}},fg=${{black}}]#{{?client_prefix,#[bg=${{green}}],}} #S "
set-option -g status-right "#[fg=${{white}}] #h %I:%M %p "
set-option -g status-style "bg=${{dark_purple}},fg=${{white}}"
set-window-option -g window-status-current-format "#[fg=${{white}},bg=${{muted_purple}}] #I #W "
set-window-option -g window-status-format "#[fg=${{white}}] #I #W "
"""


def _generate_tmux_alucard_conf(dp_dir: str) -> str | None:
    """Generate a tmux light.conf with Dracula Pro Alucard colors."""
    p = _parse_ghostty_palette(dp_dir, "alucard")
    if not p:
        return None
    fg = p["foreground"]       # #383a42
    bg = "#fafafa"
    selection = "#e8e8e8"
    border_active = p["blue"]  # #a626a4
    border_inactive = "#e8e8e8"
    comment = p["comment"]     # #a0a1a7
    green = p["green"]         # #50a14f
    blue = p["blue"]           # #a626a4
    return f"""\
# Dracula Pro Alucard color palette.
# Auto-generated by koopa dotfiles install from local Dracula Pro source.

%hidden bg='{bg}'
%hidden fg='{fg}'
%hidden selection='{selection}'
%hidden comment='{comment}'
%hidden green='{green}'
%hidden blue='{blue}'
%hidden border_active='{border_active}'
%hidden border_inactive='{border_inactive}'

set-option -g message-style "bg={bg},fg={fg}"
set-option -g pane-active-border-style "fg={border_active}"
set-option -g pane-border-style "fg={border_inactive}"
set-option -g status-left "#[bg={green},fg={bg}]#{{?client_prefix,#[bg={blue}],}} #S "
set-option -g status-right "#[fg={fg}] #h %I:%M %p "
set-option -g status-style "bg={bg},fg={fg}"
set-window-option -g window-status-current-format "#[fg={fg},bg={selection}] #I #W "
set-window-option -g window-status-format "#[fg={comment}] #I #W "
"""


def _generate_kitty_dracula_pro_conf(dp_dir: str, variant: str) -> str | None:
    """Generate a kitty theme .conf with Dracula Pro colors for the given variant."""
    p = _parse_ghostty_palette(dp_dir, variant)
    if not p:
        return None
    is_light = variant == "alucard"
    bg = p["black"] if not is_light else "#fafafa"
    fg = p["foreground"]
    return f"""\
# vim:ft=kitty

## name: Dracula Pro ({variant.capitalize()})
## blurb: Auto-generated by koopa dotfiles install from local Dracula Pro source.

foreground                      {fg}
background                      {bg}
selection_foreground            {fg}
selection_background            {p["blue"]}

cursor                          {fg}
cursor_text_color               {bg}

active_border_color     {p["blue"]}
inactive_border_color   {p["comment"]}

active_tab_foreground   {bg}
active_tab_background   {fg}
inactive_tab_foreground {p["comment"]}
inactive_tab_background {p["black_bright"]}

color0  {p["black"]}
color8  {p["black_bright"]}
color1  {p["red"]}
color9  {p["red_bright"]}
color2  {p["green"]}
color10 {p["green_bright"]}
color3  {p["yellow"]}
color11 {p["yellow_bright"]}
color4  {p["blue"]}
color12 {p["blue_bright"]}
color5  {p["magenta"]}
color13 {p["magenta_bright"]}
color6  {p["cyan"]}
color14 {p["cyan_bright"]}
color7  {fg}
color15 {"#FFFFFF" if is_light else "#FFFFFF"}
"""


def _generate_wezterm_dracula_pro_toml(dp_dir: str, variant: str) -> str | None:
    """Generate a WezTerm TOML color scheme for a Dracula Pro variant."""
    p = _parse_ghostty_palette(dp_dir, variant)
    if not p:
        return None
    is_light = variant == "alucard"
    bg = "#fafafa" if is_light else p["black"]
    fg = p["foreground"]
    if variant == "alucard":
        name = "Dracula Pro Alucard"
    elif variant == "pro":
        name = "Dracula Pro"
    else:
        name = f"Dracula Pro ({variant.capitalize()})"
    return f"""\
[metadata]
name = "{name}"

[colors]
foreground = "{fg}"
background = "{bg}"
cursor_fg = "{bg}"
cursor_bg = "{fg}"
selection_fg = "{fg}"
selection_bg = "{p['selection_bg']}"

ansi = [
  "{p['black']}", "{p['red']}", "{p['green']}", "{p['yellow']}",
  "{p['blue']}", "{p['magenta']}", "{p['cyan']}", "{fg}",
]
brights = [
  "{p['black_bright']}", "{p['red_bright']}", "{p['green_bright']}", "{p['yellow_bright']}",
  "{p['blue_bright']}", "{p['magenta_bright']}", "{p['cyan_bright']}", "#FFFFFF",
]

[colors.tab_bar]
background = "{bg}"

[colors.tab_bar.active_tab]
bg_color = "{p['blue']}"
fg_color = "{fg}"

[colors.tab_bar.inactive_tab]
bg_color = "{p['black_bright']}"
fg_color = "{p['comment']}"

[colors.tab_bar.new_tab]
bg_color = "{bg}"
fg_color = "{p['comment']}"
"""


def _generate_atuin_dracula_pro_toml(dp_dir: str, variant: str) -> str | None:
    """Generate an atuin theme TOML for a Dracula Pro variant."""
    p = _parse_ghostty_palette(dp_dir, variant)
    if not p:
        return None
    fg = p["foreground"]
    # Alucard's ANSI 8 (comment) is #FFFFFF — invisible on light bg.
    # Use selection-background color (#a0a1a7 equivalent) as muted instead.
    comment = "#a0a1a7" if variant == "alucard" else p["comment"]
    theme_name = f"dracula-pro-{variant}" if variant != "pro" else "dracula-pro"
    return f"""\
# Atuin Dracula Pro theme ({variant}).
# Auto-generated by koopa dotfiles install from local Dracula Pro source.

[theme]
name = "{theme_name}"

[colors]
Important = "{fg}"
Title = "{fg}"
Annotation = "{comment}"
Guidance = "{p['cyan']}"
AlertInfo = "{p['green']}"
AlertWarn = "{p['yellow']}"
AlertError = "{p['red']}"
Muted = "{comment}"
"""


