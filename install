\t<key>com.barebones.bblm.verilog-hdl.wire-type</key>
\t<string>{func}</string>
\t<key>com.barebones.bblm.vhdl.comment-1</key>
\t<string>{keyword}</string>
\t<key>com.barebones.bblm.vhdl.comment-2</key>
\t<string>{comment}</string>
\t<key>com.barebones.bblm.vhdl.comment-3</key>
\t<string>{typ}</string>
\t<key>com.barebones.bblm.xml-empty</key>
\t<string>{func}</string>
\t<key>com.barebones.bblm.xml-pi</key>
\t<string>{comment}</string>
</dict>
</plist>
"""


def _sync_launchd_agent(home: str, label: str) -> None:
    """Load (or reload) a user LaunchAgent by label."""
    plist = os.path.join(home, "Library", "LaunchAgents", f"{label}.plist")
    if not os.path.isfile(plist):
        return
    uid = str(os.getuid())
    domain = f"gui/{uid}"
    launchctl = "/bin/launchctl"
    subprocess.run([launchctl, "bootout", domain, plist], capture_output=True)
    subprocess.run([launchctl, "bootstrap", domain, plist], check=True)


def _sync_systemd_user_agent(unit: str) -> None:
    """Enable and start a systemd user unit.

    Skips silently when systemctl is absent (headless/CI hosts lack a user bus).
    A non-zero exit from systemctl --user is also treated as a soft skip rather
    than a hard failure, since many minimal Linux installations have systemd
    installed but no running user session bus.
    """
    systemctl = shutil.which("systemctl")
    if not systemctl:
        return
    # daemon-reload picks up the newly deployed unit file.
    subprocess.run([systemctl, "--user", "daemon-reload"], capture_output=True)
    result = subprocess.run(
        [systemctl, "--user", "enable", "--now", unit],
        capture_output=True,
    )
    if result.returncode != 0:
        # Non-zero is expected on headless hosts; log but do not abort.
        print(
            f"Note: 'systemctl --user enable --now {unit}' exited"
            f" {result.returncode} (no user session bus? skipping)."
        )


def _dracula_iterm_name(variant: str) -> str:
    names = {
        "pro": "Dracula Pro.itermcolors",
        "blade": "Dracula Pro (Blade).itermcolors",
        "buffy": "Dracula Pro (Buffy).itermcolors",
        "lincoln": "Dracula Pro (Lincoln).itermcolors",
        "morbius": "Dracula Pro (Morbius).itermcolors",
        "van-helsing": "Dracula Pro (Van Helsing).itermcolors",
        "alucard": "Dracula Pro (Alucard).itermcolors",
    }
    return names.get(variant, "Dracula Pro.itermcolors")


def _dracula_terminal_name(variant: str) -> str:
    names = {
        "pro": "Dracula Pro.terminal",
        "blade": "Dracula Pro (Blade).terminal",
        "buffy": "Dracula Pro (Buffy).terminal",
        "lincoln": "Dracula Pro (Lincoln).terminal",
        "morbius": "Dracula Pro (Morbius).terminal",
        "van-helsing": "Dracula Pro (Van Helsing).terminal",
        "alucard": "Dracula Pro (Alucard).terminal",
    }
    return names.get(variant, "Dracula Pro.terminal")


def _configure_age(xdg_config: str) -> None:
    age_keygen = shutil.which("age-keygen")
    if not age_keygen:
        return
    age_dir = os.path.join(xdg_config, "age")
    key_file = os.path.join(age_dir, "key.txt")
    if not os.path.isfile(key_file):
        os.makedirs(age_dir, mode=0o700, exist_ok=True)
        subprocess.run(
            [age_keygen, "-o", key_file],
            capture_output=True,
            text=True,
            check=True,
        )
        os.chmod(key_file, 0o600)
    with open(key_file) as fh:
        recipient = next(
            (line.split(": ", 1)[1].strip() for line in fh if line.startswith("# public key: ")),
            None,
        )
    if not recipient:
        return
    chezmoi_config_dir = os.path.join(xdg_config, "chezmoi")
    os.makedirs(chezmoi_config_dir, mode=0o700, exist_ok=True)
    chezmoi_toml = os.path.join(chezmoi_config_dir, "chezmoi.toml")
    toml_content = (
        'encryption = "age"\n'
        "\n"
        "[age]\n"
        f'    identity = "{key_file}"\n'
        f'    recipient = "{recipient}"\n'
    )
    with open(chezmoi_toml, "w") as fh:
        fh.write(toml_content)
    os.chmod(chezmoi_toml, 0o600)


def main() -> None:
    home = os.environ.get("HOME", "")
    if not os.path.isdir(home):
        return
    chezmoi = locate("chezmoi")
    assert os.path.isfile(chezmoi) and os.access(chezmoi, os.X_OK), f"Not executable: {chezmoi}"
    prefix = str(_PREFIX)
    chezmoi_prefix = os.path.join(prefix, "chezmoi")
    koopa_pfx = koopa_prefix()
    xdg_config = xdg_config_home()
    xdg_data = xdg_data_home()
    for _d in (chezmoi_prefix, koopa_pfx, xdg_config, xdg_data):
        assert os.path.isdir(_d), f"Directory not found: {_d}"
    old_activate = os.path.join(xdg_config, "koopa", "activate")
    if os.path.islink(old_activate):
        os.unlink(old_activate)
    stale_chezmoi_src = os.path.join(xdg_data, "chezmoi")
    if os.path.islink(stale_chezmoi_src):
        os.unlink(stale_chezmoi_src)
    _add_config_link(prefix, "dotfiles")
    _configure_age(xdg_config)
    _configure_dracula_pro(home, xdg_data)
    _configure_koopa_color_mode_sync(home)
    ssh_dir = os.path.join(home, ".ssh")
    if os.path.isdir(ssh_dir):
        chmod(ssh_dir, "0700")
        auth_keys = os.path.join(ssh_dir, "authorized_keys")
        if os.path.isfile(auth_keys):
            chmod(auth_keys, "0600")
        ssh_config = os.path.join(ssh_dir, "config")
        if os.path.isfile(ssh_config):
            chmod(ssh_config, "0600")
    _color_sync_plist = os.path.join(
        home, "Library", "LaunchAgents", "com.koopa.color-mode-sync.plist"
    )
    _color_sync_is_new = is_macos() and not os.path.isfile(_color_sync_plist)
    _dp_dir = os.path.join(xdg_data, "dracula-pro")
    _color_sched_has_dp = is_macos() and os.path.isdir(_dp_dir)
    _color_sched_plist = os.path.join(
        home, "Library", "LaunchAgents", "com.koopa.color-mode-schedule.plist"
    )
    _color_sched_is_new = _color_sched_has_dp and not os.path.isfile(_color_sched_plist)
    # Always derive color mode from the OS before rendering templates.
    # Never trust inherited env — stale KOOPA_COLOR_MODE from a long-running
    # caller would silently render the wrong palette.
    os.environ["KOOPA_COLOR_MODE"] = os_appearance_mode()
    chezmoi_args = [
        chezmoi,
        "--force",
        "--no-pager",
        f"--source={chezmoi_prefix}",
    ]
    if os.environ.get("KOOPA_VERBOSE") == "1":
        chezmoi_args.append("--verbose")
    chezmoi_args.append("apply")
    subprocess.run(chezmoi_args, cwd=chezmoi_prefix, check=True)
    # Xcode: deploy free Dracula theme (Pro block in _configure_dracula_pro_post handles Pro variants).
    if is_macos():
        xcode_themes = os.path.join(
            home, "Library", "Developer", "Xcode", "UserData", "FontAndColorThemes"
        )
        xcode_free_src = os.path.join(prefix, "etc", "xcode", "Dracula.xccolortheme")
        if os.path.isfile(xcode_free_src):
            mkdir(xcode_themes)
            xcode_free_dest = os.path.join(xcode_themes, "Dracula.xccolortheme")
            if not os.path.islink(xcode_free_dest) and not os.path.isfile(xcode_free_dest):
                ln(xcode_free_src, xcode_free_dest)
    _configure_dracula_pro_post(home, xdg_data)
    _configure_jetbrains(home)
    if is_macos():
        _sync_launchd_agent(home, "com.koopa.color-mode-sync")
        if _color_sync_is_new:
            print(
                "Installed launch agent: com.koopa.color-mode-sync\n"
                "  Location: ~/Library/LaunchAgents/"
                "com.koopa.color-mode-sync.plist\n"
                "  Purpose: automatically re-applies dotfiles when macOS\n"
                "           switches between dark and light mode.\n"
                "  Note: macOS may show a notification that 'sh' is running\n"
                "        in the background. This is expected and safe."
            )
        if _color_sched_has_dp:
            _sync_launchd_agent(home, "com.koopa.color-mode-schedule")
            if _color_sched_is_new:
                print(
                    "Installed launch agent: com.koopa.color-mode-schedule\n"
                    "  Location: ~/Library/LaunchAgents/"
                    "com.koopa.color-mode-schedule.plist\n"
                    "  Purpose: sets macOS appearance on a fixed daily schedule\n"
                    "           (dark before 9am, light 9am-5pm, dark after 5pm),\n"
                    "           in the machine's local timezone.\n"
                    "  Note: macOS may show a notification that 'sh' is running\n"
                    "        in the background. This is expected and safe."
                )
    elif is_linux():
        _sync_systemd_user_agent("koopa-color-mode-sync.service")
    zprofile_src = os.path.join(xdg_config, "zsh", ".zprofile")
    zprofile_dest = os.path.join(home, ".zprofile")
    if not os.path.islink(zprofile_dest):
        ln(zprofile_src, zprofile_dest)
    zshrc_src = os.path.join(xdg_config, "zsh", ".zshrc")
    zshrc_dest = os.path.join(home, ".zshrc")
    if not os.path.islink(zshrc_dest):
        ln(zshrc_src, zshrc_dest)
    if is_macos():
        app_support = os.path.join(home, "Library", "Application Support")
        # VS Code.
        code_dir = os.path.join(app_support, "Code", "User")
        mkdir(code_dir)
        for f in ("keybindings.json", "settings.json"):
            dest = os.path.join(code_dir, f)
            if not os.path.islink(dest):
                ln(os.path.join(xdg_config, "Code", "User", f), dest)
        # Cursor.
        cursor_dir = os.path.join(app_support, "Cursor", "User")
        if os.path.isdir(os.path.join(app_support, "Cursor")):
            mkdir(cursor_dir)
            cursor_dest = os.path.join(cursor_dir, "settings.json")
            if not os.path.islink(cursor_dest):
                ln(os.path.join(xdg_config, "Cursor", "User", "settings.json"), cursor_dest)
        # Antigravity IDE. The app-support folder may be "Antigravity IDE" or
        # "Antigravity" depending on the installed version; try both.
        for ag_app_name in ("Antigravity IDE", "Antigravity"):
            if os.path.isdir(os.path.join(app_support, ag_app_name)):
                ag_dir = os.path.join(app_support, ag_app_name, "User")
                mkdir(ag_dir)
                for f in ("keybindings.json", "settings.json"):
                    ag_dest = os.path.join(ag_dir, f)
                    if not os.path.islink(ag_dest):
                        ln(
                            os.path.join(xdg_config, "Antigravity", "User", f),
                            ag_dest,
                        )
                break
        # Positron.
        positron_dir = os.path.join(app_support, "Positron", "User")
        mkdir(positron_dir)
        positron_dest = os.path.join(positron_dir, "settings.json")
        if not os.path.islink(positron_dest):
            ln(
                os.path.join(xdg_config, "Positron", "User", "settings.json"),
                positron_dest,
            )
        # nushell.
        nushell_dir = os.path.join(app_support, "nushell")
        if os.path.islink(nushell_dir):
            rm(nushell_dir)
        mkdir(nushell_dir)
        for f in ("config.nu", "env.nu"):
            dest = os.path.join(nushell_dir, f)
            if not os.path.islink(dest):
                ln(os.path.join(xdg_config, "nushell", f), dest)
        # ruff.
        ruff_dir = os.path.join(app_support, "ruff")
        if os.path.islink(ruff_dir):
            rm(ruff_dir)
        mkdir(ruff_dir)
        ruff_dest = os.path.join(ruff_dir, "pyproject.toml")
        if not os.path.islink(ruff_dest):
            ln(
                os.path.join(xdg_config, "ruff", "pyproject.toml"),
                ruff_dest,
            )


if __name__ == "__main__":
    main()
