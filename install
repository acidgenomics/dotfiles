        "50fa7b": green[1:].lower(),        # green
        "f1fa8c": yellow[1:].lower(),       # yellow
        "ff5555": red[1:].lower(),          # red
        "8be9fd": cyan[1:].lower(),         # cyan
        "ffffff": caret[1:].lower(),        # caret / pure white
