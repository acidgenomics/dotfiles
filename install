]


def _generate_zsh_dracula_pro_palette(dp_dir: str, variant: str) -> str | None:
    """Generate ~/.config/zsh/dracula-pro-colors.zsh from local Dracula Pro source."""
    p = _parse_ghostty_palette(dp_dir, variant)
    if not p:
        return None
    autosuggest_ansi = {
        "pro": "fg=103",
        "blade": "fg=109",
        "buffy": "fg=139",
        "lincoln": "fg=144",
        "morbius": "fg=138",
        "van-helsing": "fg=109",
        "alucard": "fg=103",
    }.get(variant, "fg=103")
    lines = [
        f"# Dracula Pro zsh syntax-highlighting palette ({variant}).",
        "# Auto-generated by koopa dotfiles install from local Dracula Pro source.",
        f"export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='{autosuggest_ansi}'",
        "ZSH_HIGHLIGHT_HIGHLIGHTERS=('main' 'cursor')",
        "typeset -gA ZSH_HIGHLIGHT_STYLES",
    ]
    color_map = {
        "foreground":   p["foreground"],
        "red":          p["red"],
        "green":        p["green"],
        "yellow":       p["yellow"],
        "blue":         p["blue"],
        "magenta":      p["magenta"],
        "cyan":         p["cyan"],
        "comment":      p["comment"],
    }
    for role, color_key in _ZSH_HIGHLIGHT_ROLES:
        if color_key is None:
            lines.append(f"ZSH_HIGHLIGHT_STYLES['{role}']='standout'")
        elif color_key == "green_italic":
            lines.append(
                f"ZSH_HIGHLIGHT_STYLES['{role}']='fg={color_map['green']},italic'"
            )
        elif color_key == "yellow_italic":
            lines.append(
                f"ZSH_HIGHLIGHT_STYLES['{role}']='fg={color_map['yellow']},italic'"
            )
        else:
            hex_val = color_map.get(color_key, p.get(color_key, "#F8F8F2"))
            lines.append(f"ZSH_HIGHLIGHT_STYLES['{role}']='fg={hex_val}'")
    fg = p["foreground"]
    bg = "#fafafa" if variant == "alucard" else p["black"]
    hl = p["blue"]
    sel_bg = p["selection_bg"]
    lines.append(
        f"export FZF_DEFAULT_OPTS='"
        f"--color=fg:{fg},bg:{bg},hl:{hl} "
        f"--color=fg+:{fg},bg+:{sel_bg},hl+:{hl} "
        f"--color=info:{p['yellow']},prompt:{p['green']},pointer:{p['magenta']} "
        f"--color=marker:{p['magenta']},spinner:{p['yellow']},header:{p['comment']}'"
    )
    return "\n".join(lines) + "\n"


def _tmtheme_colors(dp_dir: str, variant: str) -> dict[str, str] | None:
    """Parse key colors from a Dracula Pro .tmTheme for the given variant."""
    name_map = {
        "pro": "Dracula Pro.tmTheme",
        "blade": "Dracula Pro (Blade).tmTheme",
        "buffy": "Dracula Pro (Buffy).tmTheme",
        "lincoln": "Dracula Pro (Lincoln).tmTheme",
        "morbius": "Dracula Pro (Morbius).tmTheme",
        "van-helsing": "Dracula Pro (Van Helsing).tmTheme",
        "alucard": "Dracula Pro (Alucard).tmTheme",
    }
    fname = name_map.get(variant, "Dracula Pro.tmTheme")
    path = os.path.join(dp_dir, "themes", "sublime", fname)
    if not os.path.isfile(path):
        return None
    with open(path, "rb") as fh:
        data = plistlib.load(fh)
    global_s = data["settings"][0]["settings"]
    scope_map: dict[str, str] = {}
    for item in data["settings"][1:]:
        fg = item.get("settings", {}).get("foreground", "")
        if not fg:
            continue
        for scope in item.get("scope", "").split(","):
            scope_map[scope.strip()] = fg
    return {
        "background":    global_s.get("background", "#282a36"),
        "foreground":    global_s.get("foreground", "#f8f8f2"),
        "selection":     global_s.get("selection", "#44475a"),
        "line_highlight": global_s.get("lineHighlight", "#44475a"),
        "comment":       scope_map.get("comment", "#000000"),
        "string":        scope_map.get("string", "#f1fa8c"),
        "number":        scope_map.get("constant.numeric", "#bd93f9"),
        "keyword":       scope_map.get("keyword", "#ff79c6"),
        "function":      scope_map.get("entity.name.function", "#50fa7b"),
        "type":          scope_map.get("storage.type", "#8be9fd"),
        "variable":      scope_map.get("variable.parameter", "#ffb86c"),
        "is_dark":       global_s.get("background", "#282a36")[1:3].lower() < "80",
        "red":           scope_map.get("message.error", "#F83333"),
    }


# Free Dracula color → CSS property role mapping used for substitution.
# Each entry is (free_hex, role_key) in lowercase for case-insensitive matching.
_FREE_DRACULA_COLOR_MAP = [
    ("#282a36", "background"),
    ("#21222c", "background"),    # slightly darker bg variant
    ("#6272a4", "comment"),
    ("#50fa7b", "function"),
    ("#f1fa8c", "string"),
    ("#ff79c6", "keyword"),
    ("#bd93f9", "number"),
    ("#8be9fd", "type"),
    ("#ffb86c", "variable"),
]


def _generate_rstudio_rstheme(
    dp_dir: str,
    variant: str,
    template_path: str,
) -> str | None:
    """Generate an .rstheme CSS by replacing free Dracula colors with Pro colors."""
    colors = _tmtheme_colors(dp_dir, variant)
    if not colors:
        return None
    with open(template_path) as fh:
        css = fh.read()
    # Strip the old theme name header and replace with Pro name.
    variant_display_map = {
        "pro": "Dracula Pro",
        "blade": "Dracula Pro Blade",
        "buffy": "Dracula Pro Buffy",
        "lincoln": "Dracula Pro Lincoln",
        "morbius": "Dracula Pro Morbius",
        "van-helsing": "Dracula Pro Van Helsing",
        "alucard": "Dracula Pro Alucard",
    }
    display_name = variant_display_map.get(variant, "Dracula Pro")
    is_dark = "TRUE" if colors["is_dark"] else "FALSE"
    css = re.sub(
        r'/\* rs-theme-name:.*?\*/',
        f'/* rs-theme-name: {display_name} */',
        css,
    )
    css = re.sub(
        r'/\* rs-theme-is-dark:.*?\*/',
        f'/* rs-theme-is-dark: {is_dark} */',
        css,
    )
    # Substitute each free Dracula color with the Pro equivalent.
    role_to_pro = {
        "background": colors["background"],
        "comment":    colors["comment"],
        "function":   colors["function"],
        "string":     colors["string"],
        "keyword":    colors["keyword"],
        "number":     colors["number"],
        "type":       colors["type"],
        "variable":   colors["variable"],
    }
    color_map = list(_FREE_DRACULA_COLOR_MAP)
    # Light variants (e.g. Alucard): the dark template's UI-chrome colors and
    # ANSI base palette must also be remapped; dark variants are unchanged.
    if not colors["is_dark"]:
        bg = colors["background"]
        fg = colors["foreground"]
        muted = _hex_lerp(fg, bg, 0.45)
        role_to_pro.update({
            "foreground": fg,
            "panel_bg":   _hex_lerp(bg, "#000000", 0.06),
            "deep_bg":    _hex_lerp(bg, "#000000", 0.12),
            "hover_bg":   _hex_lerp(bg, "#000000", 0.10),
            "border":     _hex_lerp(bg, fg, 0.18),
            "selection":  colors["selection"],
            "muted":      muted,
        })
        color_map += [
            ("#f8f8f2", "foreground"),
            ("#252631", "panel_bg"),
            ("#1a1b22", "deep_bg"),
            ("#32343f", "hover_bg"),
            ("#303140", "border"),
            ("#464b5d", "selection"),   # alpha suffix (#464B5D80) preserved by re.sub
            ("#adb5cb", "muted"),
            ("#4b5578", "muted"),
        ]
        # Remap ANSI base palette (indices 0-15 only; 16-255 are the standard
        # xterm color cube — protocol-literal, must not be changed).
        ansi = _parse_ghostty_palette(dp_dir, "alucard")
        if ansi:
            tango_to_alucard = [
                ("#2e3436", ansi["black"]),           # 0
                ("#cc0000", ansi["red"]),              # 1
                ("#4e9a06", ansi["green"]),            # 2
                ("#c4a000", ansi["yellow"]),           # 3
                ("#3465a4", ansi["blue"]),             # 4
                ("#75507b", ansi["magenta"]),          # 5
                ("#06989a", ansi["cyan"]),             # 6
                ("#d3d7cf", ansi["foreground"]),       # 7 (ANSI white → palette fg)
                ("#555753", ansi["black_bright"]),     # 8
                ("#ef2929", ansi["red_bright"]),       # 9
                ("#8ae234", ansi["green_bright"]),     # 10
                ("#fce94f", ansi["yellow_bright"]),    # 11
                ("#729fcf", ansi["blue_bright"]),      # 12
                ("#ad7fa8", ansi["magenta_bright"]),   # 13
                ("#34e2e2", ansi["cyan_bright"]),      # 14
                ("#eeeeec", ansi["foreground"]),       # 15 (bright white → palette fg)
            ]
            for free_hex, pro_hex in tango_to_alucard:
                css = re.sub(re.escape(free_hex), pro_hex, css, flags=re.IGNORECASE)
    for free_hex, role in color_map:
        pro_hex = role_to_pro.get(role, free_hex)
        css = re.sub(re.escape(free_hex), pro_hex, css, flags=re.IGNORECASE)
    return css


def _hex_lerp(c1: str, c2: str, t: float) -> str:
    """Linearly interpolate between two hex colors."""
    r1, g1, b1 = int(c1[1:3], 16), int(c1[3:5], 16), int(c1[5:7], 16)
    r2, g2, b2 = int(c2[1:3], 16), int(c2[3:5], 16), int(c2[5:7], 16)
    r = int(r1 + (r2 - r1) * t)
    g = int(g1 + (g2 - g1) * t)
    b = int(b1 + (b2 - b1) * t)
    return f"#{r:02X}{g:02X}{b:02X}"


def _generate_bbedit_dracula_pro(dp_dir: str, variant: str) -> str | None:
    """Generate a .bbColorScheme plist XML for a Dracula Pro variant."""
    colors = _tmtheme_colors(dp_dir, variant)
    if not colors:
        return None
    bg = colors["background"]
    fg = colors["foreground"]
    sel = colors["selection"]
    line_hl = colors["line_highlight"]
    if colors["is_dark"] and sel.lower() == line_hl.lower():
        line_hl = _hex_lerp(bg, sel, 0.40)
        secondary_sel = sel
        sel = _hex_lerp(bg, sel, 1.70)
        highlight_insertion_point = True
    else:
        secondary_sel = sel
        highlight_insertion_point = bool(colors["is_dark"])
    comment = colors["comment"]
    string = colors["string"]
    number = colors["number"]
    keyword = colors["keyword"]
    func = colors["function"]
    typ = colors["type"]
    variable = colors["variable"]
    red = colors.get("red", "#F83333")
    variant_display_map = {
        "pro": "Dracula Pro",
        "blade": "Dracula Pro Blade",
        "buffy": "Dracula Pro Buffy",
        "lincoln": "Dracula Pro Lincoln",
        "morbius": "Dracula Pro Morbius",
        "van-helsing": "Dracula Pro Van Helsing",
        "alucard": "Dracula Pro Alucard",
    }
    display_name = variant_display_map.get(variant, "Dracula Pro")
    return f"""\
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
\t<key>BBEditDocumentType</key>
\t<string>ColorScheme</string>
\t<key>BackgroundColor</key>
\t<string>{bg}</string>
\t<key>ColorSchemeFormatVersion</key>
\t<integer>3</integer>
\t<key>DifferenceHighlightColor</key>
\t<string>{func}</string>
\t<key>HighlightInsertionPoint</key>
\t<{"true" if highlight_insertion_point else "false"}/>
