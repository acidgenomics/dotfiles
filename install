        "alucard": "Dracula Pro (Alucard).terminal",
    }
    return names.get(variant, "Dracula Pro.terminal")


def main() -> None:
    home = os.environ.get("HOME", "")
    if not os.path.isdir(home):
        return
    chezmoi = locate("chezmoi")
    assert os.path.isfile(chezmoi) and os.access(chezmoi, os.X_OK), f"Not executable: {chezmoi}"
    prefix = str(_PREFIX)
    chezmoi_prefix = os.path.join(prefix, "chezmoi")
    koopa_pfx = koopa_prefix()
    xdg_config = xdg_config_home()
    xdg_data = xdg_data_home()
    for _d in (chezmoi_prefix, koopa_pfx, xdg_config, xdg_data):
        assert os.path.isdir(_d), f"Directory not found: {_d}"
    old_activate = os.path.join(xdg_config, "koopa", "activate")
    if os.path.islink(old_activate):
        os.unlink(old_activate)
    _add_config_link(prefix, "dotfiles")
    _configure_dracula_pro(home, xdg_data)
    ssh_dir = os.path.join(home, ".ssh")
    if os.path.isdir(ssh_dir):
        chmod(ssh_dir, "0700")
        auth_keys = os.path.join(ssh_dir, "authorized_keys")
        if os.path.isfile(auth_keys):
            chmod(auth_keys, "0600")
        ssh_config = os.path.join(ssh_dir, "config")
        if os.path.isfile(ssh_config):
            chmod(ssh_config, "0600")
    chezmoi_args = [
        chezmoi,
        "--force",
        "--no-pager",
        f"--source={chezmoi_prefix}",
    ]
    if os.environ.get("KOOPA_VERBOSE") == "1":
        chezmoi_args.append("--verbose")
    chezmoi_args.append("apply")
    subprocess.run(chezmoi_args, cwd=chezmoi_prefix, check=True)
    # Xcode: deploy free Dracula theme (Pro block in _configure_dracula_pro_post handles Pro variants).
    if is_macos():
        xcode_themes = os.path.join(
            home, "Library", "Developer", "Xcode", "UserData", "FontAndColorThemes"
        )
        xcode_free_src = os.path.join(prefix, "etc", "xcode", "Dracula.xccolortheme")
        if os.path.isfile(xcode_free_src):
            mkdir(xcode_themes)
            xcode_free_dest = os.path.join(xcode_themes, "Dracula.xccolortheme")
            if not os.path.islink(xcode_free_dest) and not os.path.isfile(xcode_free_dest):
                ln(xcode_free_src, xcode_free_dest)
    # BBEdit: set free Dracula as dark mode baseline (overridden below if Pro is installed).
    if is_macos():
        bbedit_schemes = os.path.join(
            home, "Library", "Application Support", "BBEdit", "Color Schemes"
        )
        if os.path.isdir(bbedit_schemes):
            subprocess.run(
                [
                    "/usr/bin/defaults", "write", "com.barebones.bbedit",
                    "SelectedColorSchemeNameDarkMode", "-string", "Dracula",
                ],
                check=True,
            )
    _configure_dracula_pro_post(home, xdg_data)
    zprofile_src = os.path.join(xdg_config, "zsh", ".zprofile")
    zprofile_dest = os.path.join(home, ".zprofile")
    if not os.path.islink(zprofile_dest):
        ln(zprofile_src, zprofile_dest)
    zshrc_src = os.path.join(xdg_config, "zsh", ".zshrc")
    zshrc_dest = os.path.join(home, ".zshrc")
    if not os.path.islink(zshrc_dest):
        ln(zshrc_src, zshrc_dest)
    if is_macos():
        app_support = os.path.join(home, "Library", "Application Support")
        # VS Code.
        code_dir = os.path.join(app_support, "Code", "User")
        mkdir(code_dir)
        for f in ("keybindings.json", "settings.json"):
            dest = os.path.join(code_dir, f)
            if not os.path.islink(dest):
                ln(os.path.join(xdg_config, "Code", "User", f), dest)
        # Cursor.
        cursor_dir = os.path.join(app_support, "Cursor", "User")
        if os.path.isdir(os.path.join(app_support, "Cursor")):
            mkdir(cursor_dir)
            cursor_dest = os.path.join(cursor_dir, "settings.json")
            if not os.path.islink(cursor_dest):
                ln(os.path.join(xdg_config, "Cursor", "User", "settings.json"), cursor_dest)
        # McFly.
        mcfly_dir = os.path.join(app_support, "McFly")
        mkdir(mcfly_dir)
        mcfly_dest = os.path.join(mcfly_dir, "config.toml")
        if not os.path.islink(mcfly_dest):
            ln(os.path.join(xdg_config, "mcfly", "config.toml"), mcfly_dest)
        # Positron.
        positron_dir = os.path.join(app_support, "Positron", "User")
        mkdir(positron_dir)
        positron_dest = os.path.join(positron_dir, "settings.json")
        if not os.path.islink(positron_dest):
            ln(
                os.path.join(xdg_config, "Positron", "User", "settings.json"),
                positron_dest,
            )
        # nushell.
        nushell_dir = os.path.join(app_support, "nushell")
        if os.path.islink(nushell_dir):
            rm(nushell_dir)
        mkdir(nushell_dir)
        for f in ("config.nu", "env.nu"):
            dest = os.path.join(nushell_dir, f)
            if not os.path.islink(dest):
                ln(os.path.join(xdg_config, "nushell", f), dest)
        # ruff.
        ruff_dir = os.path.join(app_support, "ruff")
        if os.path.islink(ruff_dir):
            rm(ruff_dir)
        mkdir(ruff_dir)
        ruff_dest = os.path.join(ruff_dir, "pyproject.toml")
        if not os.path.islink(ruff_dest):
            ln(
                os.path.join(xdg_config, "ruff", "pyproject.toml"),
                ruff_dest,
            )


if __name__ == "__main__":
    main()
