#!/usr/bin/env python3

"""Install dotfiles."""

import io
import json
import os
import plistlib
import re
import shutil
import subprocess
import sys
import zipfile
from pathlib import Path

_PREFIX = Path(__file__).resolve().parent
_KOOPA_PREFIX = str(_PREFIX.parents[2])
_PYTHON_SRC = os.path.join(_KOOPA_PREFIX, "lang", "python", "src")
if _PYTHON_SRC not in sys.path:
    sys.path.insert(0, _PYTHON_SRC)

from koopa.build import locate
from koopa.file_ops import chmod, ln, mkdir, rm
from koopa.prefix import koopa_prefix
from koopa.system import is_linux, is_macos, os_appearance_mode
from koopa.xdg import xdg_config_home, xdg_data_home

_DRACULA_VARIANT_NAMES = {
    "pro": "Dracula Pro",
    "blade": "Dracula Pro Blade",
    "buffy": "Dracula Pro Buffy",
    "lincoln": "Dracula Pro Lincoln",
    "morbius": "Dracula Pro Morbius",
    "van-helsing": "Dracula Pro Van Helsing",
    "alucard": "Dracula Pro Alucard",
}


def _add_config_link(source: str, name: str) -> None:
    config_dir = os.path.join(xdg_config_home(), "koopa")
    mkdir(config_dir)
    dest = os.path.join(config_dir, name)
    if os.path.islink(dest):
        return
    ln(source, dest)


def _install_vscode_extension(
    vsix: str,
    prefix: str,
    ext_dir: str,
    code: str,
    label: str,
) -> None:
    """Install a VSIX extension if not already at the current version."""
    with zipfile.ZipFile(vsix) as zf:
        pkg = json.loads(zf.read("extension/package.json"))
    source_version = pkg["version"]
    installed_version = None
    if os.path.isdir(ext_dir):
        for d in os.listdir(ext_dir):
            if d.startswith(prefix):
                ver = d[len(prefix):]
                try:
                    ver_tuple = tuple(int(x) for x in ver.split("."))
                except ValueError:
                    continue
                if installed_version is None or ver_tuple > tuple(
                    int(x) for x in installed_version.split(".")
                ):
                    installed_version = ver
    if installed_version != source_version:
        if installed_version is not None:
            print(f"Upgrading {label}: {installed_version} → {source_version}")
        subprocess.run(
            [code, "--install-extension", vsix],
            capture_output=True,
            check=True,
        )
    if os.path.isdir(ext_dir):
        for d in os.listdir(ext_dir):
            if d.startswith(prefix) and d != prefix + source_version:
                stale = os.path.join(ext_dir, d)
                try:
                    rm(stale)
                except OSError as exc:
                    print(
                        f"Warning: could not remove stale extension "
                        f"directory: {stale} ({exc})"
                    )


def _positron_cli(home: str) -> str | None:
    """Return path to Positron CLI binary, or None if not installed."""
    candidates = [
        os.path.join(
            home, "Applications", "Positron.app",
            "Contents", "Resources", "app", "bin", "code",
        ),
        "/Applications/Positron.app/Contents/Resources/app/bin/code",
    ]
    for path in candidates:
        if os.path.isfile(path) and os.access(path, os.X_OK):
            return path
    return None


def _positron_ext_dir(home: str) -> str:
    """Return Positron's extension directory path."""
    return os.path.join(home, ".positron", "extensions")


def _cursor_ext_dir(home: str) -> str:
    """Return Cursor's extension directory path."""
    return os.path.join(home, ".cursor", "extensions")


def _antigravity_ext_dir(home: str) -> str:
    """Return Antigravity's extension directory path."""
    return os.path.join(home, ".antigravity", "extensions")


