def _dracula_iterm_name(variant: str) -> str:
    names = {
        "pro": "Dracula Pro.itermcolors",
        "blade": "Dracula Pro (Blade).itermcolors",
        "buffy": "Dracula Pro (Buffy).itermcolors",
        "lincoln": "Dracula Pro (Lincoln).itermcolors",
        "morbius": "Dracula Pro (Morbius).itermcolors",
        "van-helsing": "Dracula Pro (Van Helsing).itermcolors",
        "alucard": "Dracula Pro (Alucard).itermcolors",
    }
    return names.get(variant, "Dracula Pro.itermcolors")


