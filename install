        return None
    bg = colors["background"]
    fg = colors["foreground"]
    sel = colors["selection"]
    line_hl = colors["line_highlight"]
    comment = colors["comment"]
    string = colors["string"]
    number = colors["number"]
    keyword = colors["keyword"]
    func = colors["function"]
    typ = colors["type"]
    variable = colors["variable"]
    red = colors.get("red", "#F83333")
    variant_display_map = {
        "pro": "Dracula Pro",
        "blade": "Dracula Pro Blade",
        "buffy": "Dracula Pro Buffy",
